{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "thadm - Development",
  "identifier": "com.thadm.dev",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../out",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "publisher": "Balaji Sachidanandam",
    "category": "DeveloperTool",
    "shortDescription": "24/7 memory for your desktop",
    "longDescription": "24/7 memory for your desktop. 100% local. You own your data.",
    "copyright": "",
    "targets": [
      "app",
      "dmg",
      "deb",
      "appimage",
      "nsis"
    ],
    "externalBin": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/1024x1024.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/thadm-tray-failed.png",
      "icons/thadm-tray-black.png"
    ],
    "resources": [
      "assets/*",
      "mlx.metallib"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "hardenedRuntime": true,
      "signingIdentity": "Developer ID Application: Balaji Sachidanandam (KVLNE2Y696)"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [],
      "pubkey": ""
    },
    "deep-link": {
      "desktop": {
        "schemes": [
          "thadm"
        ]
      },
      "mobile": [
        {
          "host": "screenpi.pe",
          "pathPrefix": [
            "/auth"
          ]
        },
        {
          "host": "screenpi.pe",
          "pathPrefix": [
            "/stripe-connect"
          ]
        },
        {
          "host": "screenpi.pe",
          "pathPrefix": [
            "/purchase-successful"
          ]
        },
        {
          "host": "screenpi.pe",
          "pathPrefix": [
            "/settings"
          ]
        },
        {
          "host": "screenpi.pe",
          "pathPrefix": [
            "/changelog"
          ]
        },
        {
          "host": "screenpi.pe",
          "pathPrefix": [
            "/onboarding"
          ]
        },
        {
          "host": "screenpi.pe",
          "pathPrefix": [
            "/status"
          ]
        }
      ]
    }
  },
  "app": {
    "withGlobalTauri": true,
    "trayIcon": {
      "id": "screenpipe_main",
      "iconPath": "assets/thadm-tray-white.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": true
    },
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$HOME/.thadm/**",
          "**"
        ]
      },
      "csp": null
    },
    "macOSPrivateApi": true
  }
}
